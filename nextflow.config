nextflow.enable.dsl = 2

params {
  // Selection controls
  mode              = 'chromosome'   // chromosome | top_n
  chromosomes       = '7'            // comma-separated; used in chromosome mode
  max_loci          = 10
  locus_ids         = ''             // optional comma-separated explicit locus IDs

  // Execution behavior
  continue_on_error = true
  docker_image      = 'ensemblorg/ensembl-vep:release_115.2'
  run_benchmark     = false

  // Integration/export
  postgres_dsn      = System.getenv('TARGET_DISCOVERY_PG_DSN') ?: ''

  // Runtime paths
  repo_root         = projectDir
  python_bin        = '.venv/bin/python'
}

process {
  executor = 'local'
  errorStrategy = 'terminate'
  shell = ['/bin/bash', '-euo', 'pipefail']
}

profiles {
  standard { }

  benchmark {
    params.run_benchmark = true
  }

  one_locus {
    params.mode = 'top_n'
    params.max_loci = 1
  }
}

